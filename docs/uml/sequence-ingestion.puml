@startuml
title INGEST PIPE - PDF Upload Flow

actor User
participant "UploadButton\n(FRONTEND)" as FE
participant "POST /api/ingest\nExpress Route" as Route
participant "Multer\nMiddleware" as Multer
participant "IngestController" as Controller
participant "HostedIngestService" as IngestService
database "document.db\n(SQLite)" as DB
participant "OpenAI Files" as Files
participant "OpenAI VectorStore" as VS

User -> FE: Select PDF
FE -> Route: POST /api/ingest (multipart/form-data)
Route -> Multer: Parse form-data\nExtract req.file
Multer --> Route: req.file = { buffer, originalname }

Route -> Controller: ingest(req)
Controller -> Controller: Compute SHA256(file.buffer)
Controller -> DB: findByHash(hash)
DB --> Controller: existing or null

alt Duplicate found
    Controller -> FE: 409 Duplicate\n{docId, displayName}
    return
end

Controller -> Controller: docId = randomUUID()

Controller -> IngestService: uploadFile(buffer, filename, docId)

IngestService -> Files: files.create(file)
Files --> IngestService: fileId

IngestService -> VS: vectorStores.files.create(\nfile_id=fileId,\nattributes={docId,filename})
VS --> IngestService: vectorStoreFileId

IngestService -> VS: Poll until status=completed

IngestService --> Controller: {fileId, vectorStoreFileId}

Controller -> DB: INSERT document record\n(id, fileId, vectorStoreId,\nfilename, vectorStoreFileId, hash)
DB --> Controller: OK

Controller --> FE: {status:"ok", docId, displayName}

@enduml